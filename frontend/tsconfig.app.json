{
    "compilerOptions": {
        "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
        "target": "es2023",
        "lib": ["ES2023", "DOM"],
        "module": "esnext",
        "types": ["vite/client"],
        "skipLibCheck": true,
        /* Bundler mode */
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "verbatimModuleSyntax": true,
        "moduleDetection": "force",
        "noEmit": true,
        "jsx": "react-jsx",
        /* Linting */
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "erasableSyntaxOnly": true,
        "noFallthroughCasesInSwitch": true,
        "strict": true,
        "paths": {
            "@auth": ["./src/features/auth"],
            "@auth/*": ["./src/features/auth/*"],
            "@calendar": ["./src/features/calendar"],
            "@calendar/*": ["./src/features/calendar/*"],
            "@leaderboard": ["./src/features/leaderboard"],
            "@leaderboard/*": ["./src/features/leaderboard/*"],
            "@map": ["./src/features/map"],
            "@map/*": ["./src/features/map/*"],

            "@/*": ["./src/*"],
            "@assets": ["./src/assets"],
            "@assets/*": ["./src/assets/*"],
            "@components": ["./src/components"],
            "@components/*": ["./src/components/*"],
            "@constants": ["./src/constants"],
            "@constants/*": ["./src/constants/*"],
            "@features": ["./src/features"],
            "@features/*": ["./src/features/*"],
            "@hooks": ["./src/hooks"],
            "@hooks/*": ["./src/hooks/*"],
            "@layouts": ["./src/layouts"],
            "@layouts/*": ["./src/layouts/*"],
            "@pages": ["./src/pages"],
            "@pages/*": ["./src/pages/*"],
            "@routes": ["./src/routes"],
            "@routes/*": ["./src/routes/*"],
            "@services": ["./src/services"],
            "@services/*": ["./src/services/*"]
        }
    },
    "include": ["src"]
}
