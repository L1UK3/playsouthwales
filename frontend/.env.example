# Play South Wales - Vite Frontend Environment Variables Example
# Copy this file to '.env' and fill in your values.

# Google Maps API Configuration
# Get a key from Google Cloud Console with Maps JavaScript API enabled
VITE_GOOGLE_MAPS_API_KEY=AIzaSy...

# Clerk Auth Configuration
# Obtain publishable key from your Clerk Dashboard (https://clerk.com)
VITE_CLERK_API_KEY=pk_test_...

# API Gateway Routing
# Proxy backend route prefix used by Vite dev server
VITE_API_URL=/api
