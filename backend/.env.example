# Play South Wales - FastAPI Backend Environment Variables Example
# Copy this file to '.env' and fill in your values.

# Clerk Auth Configuration
# Obtain secret key from your Clerk Dashboard (https://clerk.com)
CLERK_SECRET_KEY=sk_test_...

# Optional Clerk Configurations
# CLERK_JWT_KEY=                        # Public key to verify JWTs locally (PEM format)
# CLERK_AUTHORIZED_PARTIES=             # Comma-separated list of allowed origins (defaults: http://localhost:5173, etc.)
# CLERK_WEBHOOK_SIGNING_SECRET=         # Webhook secret to verify webhooks from Clerk

# Supabase Local Configuration
# Set these using the output from running 'npx supabase start'
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_KEY=eyJhbGciOi...              # Anon public key (optional for backend, but defined in env)
SUPABASE_SECRET_KEY=eyJhbGciOi...       # service_role secret key (required to bypass RLS)

# Postgres Database URL (used for local connections / migrations)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Allowed CORS Origins (optional, comma-separated list of origins)
# ALLOWED_ORIGINS=http://localhost:5173
