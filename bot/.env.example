# Discord Bot Configuration
# Retrieve these values from the Discord Developer Portal: https://discord.com/developers/applications

# The secret bot token (keep this private, do not commit .env to version control!)
BOT_TOKEN=your_bot_token_here

# The Client ID (Application ID) of your bot
CLIENT_ID=your_client_id_here

# Optional: The ID of your development guild (server) for instant command synchronization
GUILD_ID=your_guild_id_here
